{
	"name": "sitegeist",
	"version": "0.1.0",
	"private": true,
	"description": "AI-powered browser extension for web navigation and interaction",
	"type": "module",
	"main": "dist/background.js",
	"scripts": {
		"clean": "rm -rf dist-chrome",
		"build:chrome": "node ./scripts/build.mjs && tailwindcss -i ./src/app.css -o ./dist-chrome/app.css --minify",
		"build": "vp run build:chrome",
		"dev": "concurrently -n \"build,css,server\" -c \"blue,green,yellow\" \"node ./scripts/build.mjs --watch\" \"tailwindcss -i ./src/app.css -o ./dist-chrome/app.css --watch\" \"node ./scripts/dev-server.mjs\"",
		"format": "vp fmt src scripts static package.json README.md",
		"lint": "vp lint src scripts static package.json README.md",
		"typecheck": "vp exec tsc --noEmit",
		"check": "vp check --fix src scripts static package.json README.md && vp exec tsc --noEmit"
	},
	"dependencies": {
		"@mariozechner/jailjs": "^0.1.0",
		"@mariozechner/mini-lit": "workspace:^",
		"@mariozechner/pi-agent-core": "workspace:@earendil-works/pi-agent-core@^",
		"@mariozechner/pi-ai": "workspace:@earendil-works/pi-ai@^",
		"@mariozechner/pi-web-ui": "workspace:@earendil-works/pi-web-ui@^",
		"chart.js": "^4.5.1",
		"docx-preview": "^0.3.7",
		"fuse.js": "^7.1.0",
		"highlight.js": "^11.11.1",
		"js-interpreter": "^6.0.1",
		"jszip": "^3.10.1",
		"lit": "^3.3.1",
		"lucide": "^0.544.0",
		"minimatch": "^10.0.3",
		"ollama": "^0.6.0",
		"pdfjs-dist": "5.4.394",
		"three": "^0.180.0",
		"tsx": "^4.20.6",
		"xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.0.0-beta.14",
		"@types/chrome": "^0.1.24",
		"@types/webextension-polyfill": "^0.12.4",
		"concurrently": "^9.2.1",
		"esbuild": "^0.25.10",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"ws": "^8.18.0"
	}
}
