+		},
+		{
+			apiKey: "test-key",
+			...options,
+			onPayload: (payload) => {
+				capturedPayload = payload;
+				return options?.onPayload?.(payload, model) ?? payload;
+			},
+		},
+	);
+
+	for await (const event of stream) {
+		if (event.type === "done" || event.type === "error") break;
+	}
+
+	if (!capturedPayload || typeof capturedPayload !== "object") {
+		throw new Error("Expected payload capture");
+	}
+	return capturedPayload as Record<string, unknown>;
